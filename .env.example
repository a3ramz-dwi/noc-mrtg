# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_DIR=/var/www/noc
APP_URL=http://noc-mrtg.example.com
APP_ENV=production
APP_SECRET=change-me-to-a-long-random-string
APP_VERSION=1.0.0

# ---------------------------------------------------------------------------
# Database (MariaDB / MySQL)
# ---------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=noc_manager
DB_USER=noc_user
DB_PASS=change-me-database-password
DB_CHARSET=utf8mb4

# ---------------------------------------------------------------------------
# MRTG
# ---------------------------------------------------------------------------
MRTG_DIR=/var/www/mrtg
MRTG_CFG=/etc/mrtg
MRTG_BIN=/usr/bin/mrtg

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_DIR=/var/log/noc

# ---------------------------------------------------------------------------
# SNMP Defaults
# ---------------------------------------------------------------------------
SNMP_VERSION=2c
SNMP_COMMUNITY=public
SNMP_TIMEOUT=5000000
SNMP_RETRIES=2
SNMP_PORT=161

# ---------------------------------------------------------------------------
# CORS (optional — comma-separated origins)
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=
