# NOC MRTG Manager — Environment Configuration Example
# Copy this file to .env and fill in the real values.
# NEVER commit the actual .env file to version control.

APP_DIR=/var/www/noc
APP_URL=http://localhost
APP_ENV=production
APP_SECRET=change-me-to-a-long-random-secret
APP_VERSION=1.0.0

DB_HOST=localhost
DB_PORT=3306
DB_NAME=noc_manager
DB_USER=noc_user
DB_PASS=your-database-password
DB_CHARSET=utf8mb4

MRTG_DIR=/var/www/mrtg
MRTG_CFG=/etc/mrtg
MRTG_BIN=/usr/bin/mrtg

LOG_DIR=/var/log/noc

SNMP_VERSION=2c
SNMP_COMMUNITY=public
SNMP_TIMEOUT=5000000
SNMP_RETRIES=2
SNMP_PORT=161

# Comma-separated list of allowed CORS origins (leave empty to disable)
CORS_ALLOWED_ORIGINS=
