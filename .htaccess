Options -Indexes

# Deny direct access to sensitive directories
RewriteEngine On

# Allow access to public/ directory assets
RewriteCond %{REQUEST_URI} ^/public/
RewriteRule ^ - [L]

# Deny access to sensitive files/dirs from root
<FilesMatch "\.(env|log|sh|sql)$">
    Deny from all
</FilesMatch>

# Deny direct access to sensitive directories (DirectoryMatch not allowed in .htaccess)
RewriteRule ^(core|modules|config|database|docs|cron|snmp|mrtg|api)/ - [F,L]
